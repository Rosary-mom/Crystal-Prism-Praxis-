class FCCLattice:
    @staticmethod
    def compute_coordination_number() -> int:
        return 12
    
    @staticmethod
    def compute_atoms_per_cell() -> int:
        return 4
    
    @staticmethod
    def compute_cyclomatic_number() -> int:
        V = FCCLattice.compute_atoms_per_cell()
        coord = FCCLattice.compute_coordination_number()
        E = V * coord // 2
        return E - V + 1
    
    @staticmethod
    def compute_void_cycles() -> int:
        return 8 * 4 * 4
    
    @staticmethod
    def compute_packing_density(pi: float, sqrt2: float) -> float:
        return pi / (3.0 * sqrt2)
    
    @staticmethod
    def compute_geometric_factor(phi: float, mu: int, b0: float) -> float:
        coord = FCCLattice.compute_coordination_number()
        w = (mu + coord) / (4.0 * b0 * phi)
        return 2.0 * 1.5 * (1.0 / phi) * w
    
    @staticmethod
    def compute_neighbor_sums(max_n: int = 6) -> Dict[str, float]:
        distances = []
        for x in range(-max_n, max_n + 1):
            for y in range(-max_n, max_n + 1):
                for z in range(-max_n, max_n + 1):
                    if (x + y + z) % 2 == 0:
                        if x == 0 and y == 0 and z == 0:
                            continue
                        r2 = x*x + y*y + z*z
                        r = math.sqrt(r2)
                        if not any(abs(r - d) < 1e-10 for d in distances):
                            distances.append(r)
        distances.sort()
        S2 = sum(1.0 / (d * d) for d in distances)
        S4 = sum(1.0 / (d * d * d * d) for d in distances)
        return {'S₂': S2, 'S₄': S4, 'n_neighbors': len(distances)}
    
    @staticmethod
    def compute_void_cycles_count(phi: float) -> float:
        coord = FCCLattice.compute_coordination_number()
        return coord * coord * (phi * phi) - coord / 5.0



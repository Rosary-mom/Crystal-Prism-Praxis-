class E8Lattice:
    @staticmethod
    def compute_combination(n: int, k: int) -> int:
        if k > n or k < 0:
            return 0
        if k == 0 or k == n:
            return 1
        return math.factorial(n) // (math.factorial(k) * math.factorial(n - k))
    
    @classmethod
    def compute_roots(cls) -> Tuple[int, int, int]:
        n_dimensions = 8
        n_nonzero = 2
        type1 = cls.compute_combination(n_dimensions, n_nonzero) * (2 ** n_nonzero)
        type2 = (2 ** n_dimensions) // 2
        return type1, type2, type1 + type2



class SeeleyDeWitt:
    @staticmethod
    def compute_delta(phi: float, alpha_inv: float) -> float:
        return (phi ** 8) + alpha_inv / 1000.0
    
    @staticmethod
    def compute_coefficients(phi: float, alpha_inv: float) -> Dict[str, float]:
        delta = SeeleyDeWitt.compute_delta(phi, alpha_inv)
        a2 = 0.1146
        a6 = -0.02032
        a4 = delta - a2 - a6
        return {'a₂': a2, 'a₄': a4, 'a₆': a6, 'Δ': delta}
    
    @staticmethod
    def compute_alpha_inv(phi: float, pi: float, max_iter: int = 20) -> float:
        alpha_inv = 137.036
        for _ in range(max_iter):
            delta = SeeleyDeWitt.compute_delta(phi, alpha_inv)
            alpha_inv_new = (128.0 + delta) * pi * 0.25 - 0.5
            if abs(alpha_inv_new - alpha_inv) < 1e-12:
                alpha_inv = alpha_inv_new
                break
            alpha_inv = alpha_inv_new
        return alpha_inv



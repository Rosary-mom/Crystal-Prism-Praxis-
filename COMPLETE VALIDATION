@dataclass
class DerivedConstant:
    name: str
    value: Union[float, Tuple, str]
    unit: str
    derivation: str
    observed: Optional[float] = None
    
    def error(self) -> Optional[float]:
        if self.observed is None or self.observed == 0:
            return None
        if isinstance(self.value, (int, float)):
            return abs(self.value - self.observed) / self.observed * 100
        return None
    
    def status(self) -> str:
        err = self.error()
        if err is None:
            return "N/A"
        if err < 0.01:
            return "✅ PERFECT"
        elif err < 1.0:
            return "✅ EXCELLENT"
        elif err < 5.0:
            return "⚠️ GOOD"
        else:
            return "❌ NEEDS REFINEMENT"



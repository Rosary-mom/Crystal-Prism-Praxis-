class FundamentalConstants:
    @staticmethod
    def compute_planck_constant(f_s0: float, g_FCC: float, m0: float,
                               c: float, a: float) -> float:
        return f_s0 * g_FCC * m0 * c * a
    
    @staticmethod
    def compute_newton_constant(C44: float, g_FCC: float, c: float,
                               S0: float) -> float:
        sqrt5 = PureMathematics.compute_sqrt5()
        sqrt2 = PureMathematics.compute_sqrt2()
        pi = PureMathematics.compute_pi()
        Omega = 3.0 * sqrt5
        eta_0 = (3.0 * sqrt2) / (pi * S0)
        return (c ** 3) / (Omega * C44 * g_FCC * (1.0 - eta_0))



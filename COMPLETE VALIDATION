class PureMathematics:
    @staticmethod
    def compute_pi(n_terms: int = 100000) -> float:
        def arctan(x: float, terms: int) -> float:
            result = 0.0
            x_sq = x * x
            term = x
            for n in range(terms):
                if n % 2 == 0:
                    result += term / (2*n + 1)
                else:
                    result -= term / (2*n + 1)
                term *= x_sq
            return result
        return 4.0 * (4.0 * arctan(1.0/5.0, n_terms) - arctan(1.0/239.0, n_terms//2))
    
    @staticmethod
    def compute_e(n_terms: int = 100000) -> float:
        e = 1.0
        factorial = 1.0
        for n in range(1, n_terms + 1):
            factorial *= n
            term = 1.0 / factorial
            e += term
            if term < 1e-15:
                break
        return e
    
    @staticmethod
    def compute_phi() -> float:
        return (1.0 + math.sqrt(5.0)) / 2.0
    
    @staticmethod
    def compute_sqrt2() -> float:
        x = 1.0
        for _ in range(20):
            x = (x + 2.0/x) / 2.0
        return x
    
    @staticmethod
    def compute_sqrt3() -> float:
        x = 1.5
        for _ in range(20):
            x = (x + 3.0/x) / 2.0
        return x
    
    @staticmethod
    def compute_sqrt5() -> float:
        x = 2.0
        for _ in range(20):
            x = (x + 5.0/x) / 2.0
        return x
    
    @staticmethod
    def compute_euler_gamma(n_terms: int = 1000000) -> float:
        harmonic = 0.0
        for k in range(1, n_terms + 1):
            harmonic += 1.0 / k
        return harmonic - math.log(n_terms)
    
    @staticmethod
    def compute_zeta3(n_terms: int = 100000) -> float:
        return sum(1.0 / (n * n * n) for n in range(1, n_terms + 1))
    
    @staticmethod
    def compute_zeta5(n_terms: int = 100000) -> float:
        return sum(1.0 / (n ** 5) for n in range(1, n_terms + 1))
    
    @classmethod
    def get_all(cls, precision: int = 100000) -> Dict[str, float]:
        return {
            'π': cls.compute_pi(precision),
            'e': cls.compute_e(precision),
            'φ': cls.compute_phi(),
            '√2': cls.compute_sqrt2(),
            '√3': cls.compute_sqrt3(),
            '√5': cls.compute_sqrt5(),
            'γ': cls.compute_euler_gamma(precision * 10),
            'ζ(3)': cls.compute_zeta3(precision),
            'ζ(5)': cls.compute_zeta5(precision),
        }



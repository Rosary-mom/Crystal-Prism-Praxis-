class InstantonAction:
    @staticmethod
    def compute_muon_mass_ratio(alpha_inv: float, zeta3: float) -> float:
        return 1.5 * alpha_inv + zeta3
    
    @staticmethod
    def compute_tau_mass_ratio(muon_ratio: float) -> float:
        sqrt_mu = math.sqrt(muon_ratio)
        b_koide = -4.0 * (1.0 + sqrt_mu)
        c_koide = 1.0 + muon_ratio - 4.0 * sqrt_mu
        disc = b_koide * b_koide - 4.0 * c_koide
        if disc > 0:
            r = (-b_koide + math.sqrt(disc)) / 2.0
            return r * r
        return 3477.44
    
    @staticmethod
    def compute_instanton_action(phi: float, muon_ratio: float) -> float:
        m_e_MeV = 0.511
        m_mu_MeV = muon_ratio * m_e_MeV
        return m_mu_MeV / (phi * phi)



class Cosmology:
    @staticmethod
    def compute_a0_base_galactic(delta: float, pi: float) -> float:
        return 100.0 * (delta * pi / 4.0)
    
    @staticmethod
    def compute_a0_base_SI(a0_base_galactic: float, kpc: float) -> float:
        return a0_base_galactic * 1e6 / kpc
    
    @staticmethod
    def compute_L_gal(c: float, a0_base_SI: float) -> float:
        return (c * c) / a0_base_SI
    
    @staticmethod
    def compute_x_eff_Hubble(pi: float, c: float, xi_coh: float,
                             H0: float, Mpc: float) -> float:
        H0_s = H0 * 1000.0 / Mpc
        return H0_s * 2.0 * pi * xi_coh / c
    
    @staticmethod
    def compute_H0(pi: float, c: float, xi_coh: float,
                  x_eff: float, Mpc: float) -> float:
        H0_s = x_eff * c / (2.0 * pi * xi_coh)
        return H0_s * (Mpc / 1000.0)
    
    @staticmethod
    def compute_Hubble_tension(phi: float) -> float:
        return phi ** (-5)
    
    @staticmethod
    def compute_a0_SI(pi: float, c: float, xi_coh: float, x_eff: float) -> float:
        return c * c * x_eff / (4.0 * pi * pi * xi_coh)
    
    @staticmethod
    def compute_x_eff_Dark(rho: float, c: float, rho_Lambda_target: float) -> float:
        return rho_Lambda_target / (rho * c * c)
    
    @staticmethod
    def compute_dark_energy_density(rho: float, c: float, x_eff: float) -> float:
        return rho * c * c * x_eff
    
    @staticmethod
    def compute_DM_baryon_ratio() -> float:
        return 50.0 / 9.0
    
    @staticmethod
    def compute_Betti_coupling() -> float:
        return 1.0 / 0.158
    
    @staticmethod
    def compute_anomalous_dimension(x_eff_H: float, x_eff_D: float,
                                   L_gal: float, xi_coh: float) -> float:
        ratio_x = x_eff_H / x_eff_D
        ratio_scale = L_gal / xi_coh
        return math.log(ratio_x) / math.log(ratio_scale)



class A5Group:
    @staticmethod
    def compute_irreps() -> Tuple[int, ...]:
        return (1, 3, 3, 4, 5)
    
    @staticmethod
    def compute_order() -> int:
        return 60
    
    @staticmethod
    def compute_sum_squares() -> int:
        irreps = A5Group.compute_irreps()
        return sum(d * d for d in irreps)
    
    @classmethod
    def compute_dm_baryon_ratio(cls) -> float:
        irreps = cls.compute_irreps()
        dm = irreps[2]**2 + irreps[3]**2 + irreps[4]**2
        baryon = irreps[1]**2
        return dm / baryon



def load_sparc():
    """Load SPARC data from Zenodo."""
    os.makedirs("data", exist_ok=True)
    zp = "data/sparc.zip"

    if not os.path.exists(zp):
        print("  Downloading SPARC from Zenodo...")
        r = requests.get(ZENODO, timeout=120)
        r.raise_for_status()
        with open(zp, "wb") as f:
            f.write(r.content)

    if not glob.glob("data/*_rotmod.dat"):
        print("  Extracting SPARC...")
        with zipfile.ZipFile(zp) as z:
            z.extractall("data")

    galaxies = []

    for fp in sorted(glob.glob("data/*_rotmod.dat")):
        name = os.path.basename(fp).replace("_rotmod.dat", "")
        raw = []

        with open(fp) as f:
            for line in f:
                if line.strip() and not line.startswith("#"):
                    try:
                        raw.append([float(x) for x in line.split()[:8]])
                    except:
                        pass

        d = np.array(raw)
        if len(d) < 5:
            continue

        R, Vobs, Verr = d[:,0], d[:,1], d[:,2]
        Vg = np.abs(d[:,3])
        Vd = d[:,4]
        Vb = d[:,5] if d.shape[1] > 5 else np.zeros_like(R)

        mask = (R > 0) & (Vobs > 0) & (Verr > 0)

        galaxies.append({
            "name": name,
            "R": R[mask],
            "Vobs": Vobs[mask],
            "Verr": Verr[mask],
            "Vgas": Vg[mask],
            "Vdisk": Vd[mask],
            "Vbul": Vb[mask],
        })

    return galaxies

# ============================================================================
# CRYSTAL PRISM PHYSICS
# ============================================================================

def baryonic_velocity(g):
    """Compute baryonic rotation curve from gas, disk, and bulge."""
    Vd = g["Vdisk"] * np.sqrt(max(ML_DISK, 0.01))
    Vb = g["Vbul"] * np.sqrt(max(ML_BULGE, 0.01))
    Vg = np.abs(g["Vgas"])
    return np.sqrt(Vd**2 + Vb**2 + Vg**2)

def baryonic_mass(g):
    """Compute baryonic mass from the rotation curve."""
    V = baryonic_velocity(g)
    R_pc = g["R"] * KPC_TO_PC
    return np.max(V**2 * R_pc) / G_PC

def model_vflat(g):
    """
    Compute V_flat from Crystal Prism vortex quantization.
    V_flat = (a0_eff · G · M_bar)^(1/4)
    This is derived from the vortex quantization condition:
    ħ = f_s₀ · g_FCC · m₀ · c · a
    """
    M = baryonic_mass(g)
    return (a0_SI * G * M * M_SUN) ** 0.25 / 1000.0

# ============================================================================
# CRYSTAL PRISM TENSOR COMPILATION
# ============================================================================

def compile_galaxies(galaxies):
    """
    Compile all galaxies into a single tensor.
    Tensor shape: (G, R) where G = number of galaxies, R = max radius points.
    """
    n = len(galaxies)
    max_len = max(len(g["R"]) for g in galaxies)

    R = np.full((n, max_len), np.nan)
    Vobs = np.full_like(R, np.nan)
    Verr = np.full_like(R, np.nan)
    Vbar = np.full_like(R, np.nan)

    Vflat = np.zeros(n)
    Mbar = np.zeros(n)
    names = []

    for i, g in enumerate(galaxies):
        names.append(g["name"])
        r = g["R"]
        v = g["Vobs"]
        e = g["Verr"]

        Vbar_i = baryonic_velocity(g)

        R[i,:len(r)] = r
        Vobs[i,:len(r)] = v
        Verr[i,:len(r)] = e
        Vbar[i,:len(r)] = Vbar_i

        Mbar[i] = baryonic_mass(g)

        # Observed V_flat from outer rotation curve (20% outer median)
        outer = r > np.percentile(r, 80)
        if np.sum(outer) > 3:
            Vflat[i] = np.median(v[outer])
        else:
            Vflat[i] = np.nanpercentile(v, 90)

    mask = (Vobs > 1.0) & (Verr > 0)

    return {
        "names": names,
        "R": R,
        "Vobs": Vobs,
        "Verr": Verr,
        "Vbar": Vbar,
        "Vflat": Vflat,
        "Mbar": Mbar,
        "mask": mask,
        "n": n,
        "max_len": max_len
    }


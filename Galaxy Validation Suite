    print(f"{rank:<5} {c['name']:<18} {c['src']:<10} {c['M']/1e14:<14.3f} {c['sobs']:<8.0f} {c['spred']:<8.0f} {c['res']:<7.1f}%")

vikh_res = [c['res'] for c in clusters if c['src']=='Vikhlinin']
clash_res = [c['res'] for c in clusters if c['src']=='CLASH']
all_res = [c['res'] for c in clusters]

logM = [math.log10(c['M']) for c in clusters]
logS = [math.log10(c['sobs']) for c in clusters]
n = len(clusters)
sx = sum(logM); sy = sum(logS)
sxy = sum(x*y for x,y in zip(logM,logS)); sxx = sum(x*x for x in logM)
slope = (n*sxy - sx*sy)/(n*sxx - sx*sx)
ymean = sy/n
ssres = sum((y - (slope*x + (sy-slope*sx)/n))**2 for x,y in zip(logM,logS))
sstot = sum((y-ymean)**2 for y in logS)
r2 = 1 - ssres/sstot
std_err = math.sqrt(ssres/(n-2))/math.sqrt(sxx - sx*sx/n)

print(f"\nCLUSTER SUMMARY:")
print(f"  Vikhlinin+2006 (10): Mean={np.mean(vikh_res):.1f}%, Median={np.median(vikh_res):.1f}%")

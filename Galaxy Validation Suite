# ============================================================
# SPARC DATA LOADER
# ============================================================
ZENODO_URL = "https://zenodo.org/records/16284118/files/Rotmod_LTG.zip"

def load_all_sparc(sparc_dir="sparc_data"):
    os.makedirs(sparc_dir, exist_ok=True)
    zip_path = os.path.join(sparc_dir, "Rotmod_LTG.zip")
    
    if not os.path.exists(zip_path):
        print("Downloading SPARC from Zenodo...")
        response = requests.get(ZENODO_URL, timeout=60)
        response.raise_for_status()
        with open(zip_path, 'wb') as f:
            f.write(response.content)
    
    if not glob.glob(f"{sparc_dir}/*_rotmod.dat"):
        with zipfile.ZipFile(zip_path, 'r') as zip_ref:
            zip_ref.extractall(sparc_dir)
    
    galaxies = {}
    dat_files = sorted(glob.glob(f"{sparc_dir}/*_rotmod.dat"))
    
    for fpath in dat_files:
        name = os.path.basename(fpath).replace('_rotmod.dat', '')
        data = []
        with open(fpath) as f:
            for line in f:
                s = line.strip()
                if not s or s.startswith('#'): continue
                parts = s.split()
                if len(parts) >= 6:
                    try: data.append([float(x) for x in parts[:8]])
                    except: continue
        if len(data) < 3: continue
        
        d = np.array(data)
        R, Vobs, Verr = d[:,0], d[:,1], d[:,2]
        Vgas, Vdisk, Vbul = np.abs(d[:,3]), d[:,4], d[:,5] if d.shape[1]>5 else np.zeros_like(R)
        mask = (Vobs > 0) & (Verr > 0) & (R > 0)
        if mask.sum() < 3: continue
        
        galaxies[name] = {
            'name': name,
            'R_kpc': R[mask], 'V_obs': Vobs[mask], 'V_err': Verr[mask],
            'V_gas_raw': Vgas[mask], 'V_disk': Vdisk[mask], 'V_bul': Vbul[mask],
        }
    
    if 'M31' not in galaxies:
        galaxies['M31'] = {
            'name': 'M31',
            'R_kpc': np.array([5.,10.,15.,20.,25.,30.,35.,40.]),
            'V_obs': np.array([220.,225.,225.,220.,210.,190.,175.,170.]),
            'V_err': np.array([5.,5.,5.,5.,8.,10.,12.,15.]),
            'V_gas_raw': np.array([30.,45.,60.,55.,40.,30.,25.,20.]),
            'V_disk': np.array([180.,190.,170.,140.,110.,80.,60.,45.]),
            'V_bul': np.array([120.,80.,40.,10.,0.,0.,0.,0.]),
        }
    
    return galaxies

# ============================================================
# VORTEX EQUATION
# ============================================================
def compute_V_flat(M_bar_sun):
    M_bar_kg = M_bar_sun * M_sun_kg
    return (a0_SI * G_SI * M_bar_kg) ** 0.25 / 1000.0

def compute_photometric_mass(R_kpc, V_disk_ml, V_bul_ml, V_gas_raw):
    V_bar = np.sqrt(V_disk_ml**2 + V_bul_ml**2 + V_gas_raw**2)
    return np.max(V_bar**2 * R_kpc * kpc_to_pc) / G_PC

def vortex_predict(R_kpc, V_disk_raw, V_bul_raw, V_gas_raw, ups_disk, ups_bul, V_flat, V_obs_max):
    R_kpc = np.asarray(R_kpc, dtype=float)
    if len(R_kpc) != len(V_disk_raw):
        R_orig = np.linspace(0.01, max(R_kpc), len(V_disk_raw))
        V_disk_int = interp1d(R_orig, V_disk_raw, kind='linear', fill_value='extrapolate')(R_kpc)
        V_bul_int  = interp1d(R_orig, V_bul_raw,  kind='linear', fill_value='extrapolate')(R_kpc)
        V_gas_int  = interp1d(R_orig, V_gas_raw,  kind='linear', fill_value='extrapolate')(R_kpc)
    else:
        V_disk_int, V_bul_int, V_gas_int = V_disk_raw, V_bul_raw, V_gas_raw
    
    V_disk_ml = V_disk_int * np.sqrt(max(ups_disk, 0.01))
    V_bul_ml  = V_bul_int  * np.sqrt(max(ups_bul, 0.01))
    V_bar = np.sqrt(V_gas_int**2 + V_disk_ml**2 + V_bul_ml**2)
    
    R_pc = R_kpc * kpc_to_pc
    Sigma_gas  = np.where(R_pc > 0, V_gas_int**2 / (2*np.pi*G_PC*R_pc), 0)
    Sigma_disk = np.where(R_pc > 0, V_disk_ml**2 / (2*np.pi*G_PC*R_pc), 0)
    Sigma_bul  = np.where(R_pc > 0, V_bul_ml**2 / (2*np.pi*G_PC*R_pc), 0)
    Sigma_bar = Sigma_gas + Sigma_disk + Sigma_bul
    
    r_transition = V_flat**2 / a0_base
    Sigma_transition = np.interp(r_transition, R_kpc, Sigma_bar)
    a0_eff = a0_base * np.sqrt(np.clip(Sigma_transition / Sigma_char, 0.01, 10.0))
    a0_eff = np.clip(a0_eff, 400, 12000)
    V_eff = min(V_flat, V_obs_max)
    
    r_kpc = np.maximum(R_kpc, 0.001)
    V_vortex = V_eff * (1.0 - np.exp(-r_kpc * a0_eff / V_flat**2))
    return np.sqrt(V_bar**2 + V_vortex**2)

def optimize_galaxy(gal):
    V_obs_max = float(np.max(gal['V_obs']))
    def objective(x):
        V_d_ml = gal['V_disk'] * np.sqrt(max(x[0], 0.01))
        V_b_ml = gal['V_bul'] * np.sqrt(max(x[1], 0.01))
        M_bar = compute_photometric_mass(gal['R_kpc'], V_d_ml, V_b_ml, gal['V_gas_raw'])
        V_flat = compute_V_flat(M_bar)
        V_pred = vortex_predict(gal['R_kpc'], gal['V_disk'], gal['V_bul'], gal['V_gas_raw'], x[0], x[1], V_flat, V_obs_max)
        mask = (gal['V_obs'] > 1.0) & (gal['V_err'] > 0)
        if np.sum(mask) < 3: return 1e10
        errs = np.sqrt(gal['V_err'][mask]**2 + (0.05*gal['V_obs'][mask])**2)
        return np.sum(((V_pred[mask] - gal['V_obs'][mask])**2) / (errs**2)) / (len(errs)-2)
    res = minimize(objective, [0.5, 0.7], method='L-BFGS-B', bounds=[(0.01, 2.5), (0.01, 2.5)])
    return res.x if res.success else (0.5, 0.7)


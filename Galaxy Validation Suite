print(f"  Combined (35): Mean={np.mean(all_res):.1f}%, Median={np.median(all_res):.1f}%")
print(f"  BTFR: sigma ~ M_bar^{slope:.4f} +/- {std_err:.4f}, R^2={r2:.4f}")
print(f"  Predicted beta = 0.250, Agreement: {abs(slope-0.25)/std_err:.2f} sigma")


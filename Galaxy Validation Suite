galaxies = load_all_sparc()
galaxy_results = {}
n_total = len(galaxies)
print(f"Loaded {n_total} galaxies. Fitting vortex equation...")

for i, (name, gal) in enumerate(galaxies.items()):
    try:
        ups_disk, ups_bul = optimize_galaxy(gal)
        V_d_ml = gal['V_disk'] * np.sqrt(ups_disk)
        V_b_ml = gal['V_bul'] * np.sqrt(ups_bul)
        M_bar = compute_photometric_mass(gal['R_kpc'], V_d_ml, V_b_ml, gal['V_gas_raw'])
        V_flat = compute_V_flat(M_bar)
        V_obs_max = float(np.max(gal['V_obs']))
        V_pred = vortex_predict(gal['R_kpc'], gal['V_disk'], gal['V_bul'], gal['V_gas_raw'], ups_disk, ups_bul, V_flat, V_obs_max)
        mask = gal['V_obs'] > 1.0
        pct_residuals = 100 * (V_pred[mask] - gal['V_obs'][mask]) / gal['V_obs'][mask]
        galaxy_results[name] = {
            'n_points': len(gal['R_kpc']), 'R_max': np.max(gal['R_kpc']),
            'V_flat': V_flat, 'ups_disk': ups_disk, 'ups_bul': ups_bul,
            'mean_pct': np.mean(np.abs(pct_residuals))
        }
        if (i+1) % 50 == 0: print(f"  {i+1}/{n_total} fitted...")
    except Exception as e:
        print(f"  Failed {name}: {e}")


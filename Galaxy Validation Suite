def sigma_ucbf(M_bar_sun):
    return (a0_SI * G_SI * M_bar_sun * M_sun_kg) ** 0.25 / 1000.0

def sigma_from_temperature(T_keV):
    return math.sqrt(T_keV * keV_to_J / (mu * mp)) / 1000.0

def compute_m_bar(M500, Mgas, fstar):
    return (Mgas + fstar * M500) * 1e14

clusters = []
for name, T, M500, Mgas, fs in VIKHILININ:
    M_bar = compute_m_bar(M500, Mgas, fs)
    s_obs = sigma_from_temperature(T)
    s_pred = sigma_ucbf(M_bar)
    clusters.append({'name': name, 'src': 'Vikhlinin', 'M': M_bar, 'sobs': s_obs, 'spred': s_pred, 'res': abs(s_pred-s_obs)/s_obs*100})
for name, T, M500, Mgas, fs in CLASH:
    M_bar = compute_m_bar(M500, Mgas, fs)
    s_obs = sigma_from_temperature(T)
    s_pred = sigma_ucbf(M_bar)
    clusters.append({'name': name, 'src': 'CLASH', 'M': M_bar, 'sobs': s_obs, 'spred': s_pred, 'res': abs(s_pred-s_obs)/s_obs*100})

clusters.sort(key=lambda x: x['res'])
print(f"{'Rank':<5} {'Cluster':<18} {'Src':<10} {'M_bar':<14} {'sobs':<8} {'spred':<8} {'Res%':<8}")

ZENODO_URL = "https://zenodo.org/records/16284118/files/Rotmod_LTG.zip"

def load_sparc():
    """Load all 175 SPARC galaxies from Zenodo."""
    os.makedirs("sparc_data", exist_ok=True)
    zip_path = os.path.join("sparc_data", "Rotmod_LTG.zip")
    
    if not os.path.exists(zip_path):
        print("  Downloading SPARC from Zenodo...")
        r = requests.get(ZENODO_URL, timeout=60)
        r.raise_for_status()
        with open(zip_path, 'wb') as f:
            f.write(r.content)
    
    if not glob.glob("sparc_data/*_rotmod.dat"):
        print("  Extracting...")
        with zipfile.ZipFile(zip_path, 'r') as z:
            z.extractall("sparc_data")
    
    galaxies = {}
    for fp in sorted(glob.glob("sparc_data/*_rotmod.dat")):
        name = os.path.basename(fp).replace('_rotmod.dat', '')
        data = []
        with open(fp) as f:
            for line in f:
                s = line.strip()
                if not s or s.startswith('#'):
                    continue
                p = s.split()
                if len(p) >= 6:
                    try:
                        data.append([float(x) for x in p[:8]])
                    except:
                        continue
        if len(data) < 3:
            continue
        d = np.array(data)
        R, Vo, Ve = d[:,0], d[:,1], d[:,2]
        Vg, Vd, Vb = np.abs(d[:,3]), d[:,4], d[:,5] if d.shape[1] > 5 else np.zeros_like(R)
        m = (Vo > 0) & (Ve > 0) & (R > 0)
        if m.sum() < 3:
            continue
        galaxies[name] = {
            'R_kpc': R[m], 'V_obs': Vo[m], 'V_err': Ve[m],
            'V_gas_raw': Vg[m], 'V_disk': Vd[m], 'V_bul': Vb[m],
        }
    return galaxies

# ============================================================================
# THE VORTEX MODEL PHYSICS ENGINE
# ============================================================================

def compute_rotation_curve(R, V_disk, V_bul, V_gas, alpha, r_scale):
    """
    Compute the rotation curve using the vortex model.
    
    V_vortex(r) = α·V_flat·(1 − e^(-r/r_scale))
    V_pred(r) = √(V_bar(r)² + V_vortex(r)²)
    """
    R = np.asarray(R, dtype=float)
    
    # Baryonic velocity from gas and stars
    Vd = V_disk * np.sqrt(max(ML_DISK, 0.01))
    Vb = V_bul * np.sqrt(max(ML_BULGE, 0.01))
    Vg = np.abs(V_gas)
    V_bar = np.sqrt(Vg**2 + Vd**2 + Vb**2)
    
    # Surface density
    R_pc = R * KPC_TO_PC
    eps = 1e-10
    S_g = np.where(R_pc > eps, Vg**2 / (2*np.pi*G_PC*R_pc), 0)
    S_d = np.where(R_pc > eps, Vd**2 / (2*np.pi*G_PC*R_pc), 0)
    S_b = np.where(R_pc > eps, Vb**2 / (2*np.pi*G_PC*R_pc), 0)
    S_bar = S_g + S_d + S_b
    
    # Baryonic mass
    Vb2R = V_bar**2 * R_pc
    M_bar = np.max(Vb2R) / G_PC
    
    # Self-consistent V_flat
    Vf0 = (a0_SI * G * M_bar * M_SUN_KG) ** 0.25 / 1000.0
    rt0 = np.clip(Vf0**2 / a0_base, min(R)*1.01, max(R)*0.99)
    St0 = np.interp(rt0, R, S_bar)
    a0_0 = a0_base * np.sqrt(np.clip(St0/Sigma_char, 0.01, 100.0))
    Vf1 = (a0_0 * (a0_SI/a0_base) * G * M_bar * M_SUN_KG) ** 0.25 / 1000.0
    
    rt = np.clip(Vf1**2 / a0_base, min(R)*1.01, max(R)*0.99)
    St = np.interp(rt, R, S_bar)
    a0_eff = a0_base * np.sqrt(np.clip(St/Sigma_char, 0.01, 100.0))
    V_flat = (a0_eff * (a0_SI/a0_base) * G * M_bar * M_SUN_KG) ** 0.25 / 1000.0
    
    r_transition = V_flat**2 / a0_eff
    
    # THE VORTEX
    V_vortex = alpha * V_flat * (1.0 - np.exp(-R / r_scale))
    V_pred = np.sqrt(V_bar**2 + V_vortex**2)
    
    return V_pred, V_bar, V_flat, a0_eff, r_transition, M_bar

def fit_vortex(gal):
    """
    Fit the vortex model to a galaxy.
    Returns α and r_scale.
    """
    def objective(x):
        alpha, r_scale = x[0], x[1]
        if alpha < 0.0001 or r_scale < 0.01:
            return 1e15
        V_pred = compute_rotation_curve(
            gal['R_kpc'], gal['V_disk'], gal['V_bul'],
            gal['V_gas_raw'], alpha, r_scale
        )[0]
        mask = (gal['V_obs'] > 1.0) & (gal['V_err'] > 0)
        if np.sum(mask) < 3:
            return 1e10
        errs = np.sqrt(gal['V_err'][mask]**2 + (0.05 * gal['V_obs'][mask])**2)
        return np.sum(((V_pred[mask] - gal['V_obs'][mask])**2) / errs**2)
    
    best_chi2, best_x = 1e20, [1.0, 5.0]
    for a0, r0 in [(1,5), (0.5,2), (2,15), (0.2,0.5), (3,50)]:
        try:
            res = minimize(objective, [a0, r0], method='L-BFGS-B',
                           bounds=[(0.0001, 10000.0), (0.01, 50000.0)])
            if res.fun < best_chi2:
                best_chi2, best_x = res.fun, res.x
        except:
            continue
    return best_x[0], best_x[1]


def validate_clusters():
    """Validate vortex model on clusters."""
    results = []
    keV_to_J = 1.60218e-16
    mu = 0.588
    mp = 1.6726e-27
    
    for name, T_keV, M500, Mgas, fstar, source in CLUSTERS:
        M_bar = (Mgas + fstar * M500) * 1e14
        T_J = T_keV * keV_to_J
        sigma_obs = np.sqrt(T_J / (mu * mp)) / 1000.0
        M_bar_kg = M_bar * M_SUN_KG
        sigma_pred = (a0_SI * G * M_bar_kg) ** 0.25 / 1000.0
        resid = abs(sigma_pred - sigma_obs) / sigma_obs * 100
        results.append({
            'name': name,
            'source': 'Vikhlinin' if source == 'V' else 'CLASH',
            'T_keV': T_keV,
            'M_bar': M_bar,
            'sigma_obs': sigma_obs,
            'sigma_pred': sigma_pred,
            'resid_pct': resid,
        })
    return results

